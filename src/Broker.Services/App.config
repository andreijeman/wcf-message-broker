<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<appSettings>
		<add key="aspnet:UseTaskFriendlySynchronizationContext" value="true" />
	</appSettings>

	<system.web>
		<compilation debug="true" />
	</system.web>

	<system.serviceModel>

		<services>

			<service name="Broker.Services.Services.PublisherService">
				<host>
					<baseAddresses>
						<add baseAddress="http://localhost:8080/services/publisher" />
					</baseAddresses>
				</host>

				<endpoint
					address=""
					binding="basicHttpBinding"
					contract="Broker.Contracts.Services.IPublisherService" />

				<endpoint address="mex" binding="mexHttpBinding" contract="IMetadataExchange" />
			</service>

			<service name="Broker.Services.Services.SubscriberService">
				<host>
					<baseAddresses>
						<add baseAddress="http://localhost:8080/services/subscriber" />
					</baseAddresses>
				</host>

				<endpoint
					address=""
					binding="basicHttpBinding"
					contract="Broker.Contracts.Services.ISubscriberService" />

				<endpoint address="mex" binding="mexHttpBinding" contract="IMetadataExchange" />
			</service>

			<service name="Broker.Services.Services.TopicService">
				<host>
					<baseAddresses>
						<add baseAddress="http://localhost:8080/services/topic" />
					</baseAddresses>
				</host>

				<endpoint
					address=""
					binding="basicHttpBinding"
					contract="Broker.Contracts.Services.ITopicService" />

				<endpoint address="mex" binding="mexHttpBinding" contract="IMetadataExchange" />
			</service>
		</services>

		<behaviors>
			<serviceBehaviors>
				<behavior>
					<serviceMetadata httpGetEnabled="true" />
					<serviceDebug includeExceptionDetailInFaults="true" />
				</behavior>
			</serviceBehaviors>
		</behaviors>

	</system.serviceModel>

</configuration>
