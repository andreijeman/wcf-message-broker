<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>

	<system.serviceModel>

		<services>

			<service name="Broker.Services.Services.PublisherService">
				<host>
					<baseAddresses>
						<add baseAddress="net.pipe://localhost/services/publisher" />
					</baseAddresses>
				</host>

				<endpoint address="" binding="netNamedPipeBinding" contract="Broker.Contracts.Services.IPublisherService" />
				<endpoint address="mex" binding="mexNamedPipeBinding" contract="IMetadataExchange" />
			</service>

			<service name="Broker.Services.Services.SubscriberService">
				<host>
					<baseAddresses>
						<add baseAddress="net.pipe://localhost/services/subscriber" />
					</baseAddresses>
				</host>

				<endpoint address="" binding="netNamedPipeBinding" contract="Broker.Contracts.Services.ISubscriberService" />
				<endpoint address="mex" binding="mexNamedPipeBinding" contract="IMetadataExchange" />
			</service>

			<service name="Broker.Services.Services.TopicService">
				<host>
					<baseAddresses>
						<add baseAddress="net.pipe://localhost/services/topic" />
					</baseAddresses>
				</host>

				<endpoint address="" binding="netNamedPipeBinding" contract="Broker.Contracts.Services.ITopicService" />
				<endpoint address="mex" binding="mexNamedPipeBinding" contract="IMetadataExchange" />
			</service>
		</services>

		<behaviors>
			<serviceBehaviors>
				<behavior>
					<serviceMetadata httpGetEnabled="false" />
					<serviceDebug includeExceptionDetailInFaults="true" />
				</behavior>
			</serviceBehaviors>
		</behaviors>

	</system.serviceModel>

	<system.diagnostics>
		<sources>
			<source name="System.ServiceModel"
					   switchValue="Information, ActivityTracing"
					   propagateActivity="true">
				<listeners>
					<add name="traceListener"
						type="System.Diagnostics.XmlWriterTraceListener"
						initializeData= "C:\Users\AndreiJeman\Desktop\Traces.svclog" />
				</listeners>
			</source>
		</sources>
	</system.diagnostics>
	
</configuration>